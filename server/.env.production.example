# Production backend environment example
NODE_ENV=production
PORT=10000

# Core
MONGODB_URI=YOUR_MONGODB_URI
JWT_SECRET=YOUR_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=30d

# Frontend URLs (required for CORS and links)
CLIENT_URL=https://www.devmakhana.in
FRONTEND_URL=https://www.devmakhana.in
ALLOWED_ORIGINS=https://www.devmakhana.in,https://devmakhana.in,https://www.devmakhana.com,https://devmakhana.com
API_URL=https://dev-makhana-youdog.onrender.com

# Admin bootstrap credentials
ADMIN_EMAIL=admin@devmakhanaudyog.com
ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://www.devmakhana.in/auth/google/callback

# OTP
OTP_EXPIRY_MINUTES=10
MAX_OTP_ATTEMPTS=5

# Razorpay
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# Stripe
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Cloudinary
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# SMTP/Email
EMAIL_SERVICE=smtp
SMTP_HOST=YOUR_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=YOUR_EMAIL_USER
EMAIL_PASSWORD=YOUR_EMAIL_PASSWORD
EMAIL_FROM_NAME=Dev Makhana Udyog
EMAIL_FROM_ADDRESS=no-reply@devmakhanaudyog.com
CONTACT_RECEIVER=support@devmakhanaudyog.com
